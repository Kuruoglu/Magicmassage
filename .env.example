NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gift certificate payments stay in demo mode unless Stripe keys are configured.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Live gift certificate payments require both flags and final code prices.
GIFT_CERTIFICATES_ENABLE_LIVE_PAYMENTS=false
GIFT_CERTIFICATES_FINAL_PRICES_CONFIRMED=false

# Resend is the preferred low-cost v1 email provider.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
GIFT_CERTIFICATES_OWNER_EMAIL=
